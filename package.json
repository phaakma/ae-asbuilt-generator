{
  "name": "arcgis-asbuilt-diagram-tool",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:static": "npm run build",
    "build:pages": "npm run build:static",
    "emit:js": "tsc -p tsconfig.emit.json",
    "preview": "vite preview",
    "preview:pages": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@esri/calcite-components": "^2.13.2",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "pako": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.13.10",
    "@types/pako": "^2.0.4",
    "@types/react": "^18.3.19",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^28.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  }
}
